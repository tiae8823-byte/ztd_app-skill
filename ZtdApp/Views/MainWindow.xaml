<Window x:Class="ZtdApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:ZtdApp.ViewModels.Pages"
        Style="{StaticResource MainWindowStyle}"
        Title="ZTD - 个人生产力管理"
        Width="1000"
        Height="700"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 侧边栏 -->
        <Border Grid.Column="0" Style="{StaticResource SidebarBorder}">
            <StackPanel Margin="0,20,0,0">
                <!-- Logo / 标题 -->
                <TextBlock Text="ZTD"
                           FontSize="{StaticResource FontSizeHeading}"
                           FontWeight="Bold"
                           Margin="0,0,0,30"
                           HorizontalAlignment="Center"/>

                <!-- 导航按钮 -->
                <Button Content="想法收集"
                        Command="{Binding NavigateToIdeasCommand}"
                        Style="{StaticResource NavButton}"/>
                <Button Content="待办列表"
                        Command="{Binding NavigateToTodosCommand}"
                        Style="{StaticResource NavButton}"/>
                <Button Content="今日待办"
                        Command="{Binding NavigateToTodayCommand}"
                        Style="{StaticResource NavButton}"/>
                <Button Content="笔记库"
                        Command="{Binding NavigateToNotesCommand}"
                        Style="{StaticResource NavButton}"/>
                <Button Content="每周回顾"
                        Command="{Binding NavigateToReviewCommand}"
                        Style="{StaticResource NavButton}"/>
            </StackPanel>
        </Border>

        <!-- 内容区域 -->
        <Border Grid.Column="1" Background="{StaticResource BrandLight}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                <ContentControl Content="{Binding CurrentPage}">
                    <ContentControl.Resources>
                        <!-- 想法收集页面 -->
                        <DataTemplate DataType="{x:Type viewModels:IdeaViewModel}">
                            <StackPanel>
                                <TextBlock Text="{Binding ElementName=MainWindow, Path=DataContext.CurrentTitle}"
                                           Style="{StaticResource HeadingTextBlock}"/>
                                <TextBlock Text="快速记录你的想法"
                                           Style="{StaticResource SubheadingTextBlock}"/>
                                <TextBox Text="{Binding InputContent, UpdateSourceTrigger=PropertyChanged}"
                                         KeyDown="OnKeyDown"
                                         Margin="0,0,0,10"/>
                                <Button Content="添加想法"
                                        Command="{Binding AddIdeaCommand}"
                                        Height="44"
                                        Width="120"
                                        HorizontalAlignment="Left"/>
                                <ItemsControl ItemsSource="{Binding Ideas}" Margin="0,20,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardBorder}" Cursor="Hand">
                                                <StackPanel>
                                                    <!-- 卡片头部：内容 + 删除按钮 -->
                                                    <Grid>
                                                        <Grid.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                                                                        Command="{Binding DataContext.ToggleExpandCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}"/>
                                                        </Grid.InputBindings>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                            <TextBlock Text="{Binding Content}"
                                                                       TextWrapping="Wrap"
                                                                       FontSize="{StaticResource FontSizeMedium}"
                                                                       Margin="0,0,0,4"/>
                                                            <TextBlock Text="{Binding CreatedAtDisplay}"
                                                                       Foreground="{StaticResource BrandMidGray}"
                                                                       Opacity="0.8"
                                                                       FontSize="{StaticResource FontSizeSmall}"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="1"
                                                                Content="删除"
                                                                Command="{Binding DataContext.DeleteIdeaCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding Id}"
                                                                Style="{StaticResource DeleteButton}"/>
                                                    </Grid>

                                                    <!-- 操作按钮区域（展开时显示） -->
                                                    <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                Margin="0,10,0,0">
                                                        <Border BorderBrush="{StaticResource BrandLightGray}"
                                                                BorderThickness="0,1,0,0"
                                                                Padding="0,10,0,0">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Button Command="{Binding DataContext.ConvertToTodoCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding Id}"
                                                                        Style="{StaticResource SecondaryButton}"
                                                                        Width="100"
                                                                        Height="36"
                                                                        VerticalContentAlignment="Center"
                                                                        Margin="0,0,8,0">
                                                                    <TextBlock Text="待办" TextWrapping="NoWrap" VerticalAlignment="Center"/>
                                                                </Button>
                                                                <Button Command="{Binding DataContext.ConvertToNoteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding Id}"
                                                                        Style="{StaticResource SecondaryButton}"
                                                                        Width="100"
                                                                        Height="36"
                                                                        VerticalContentAlignment="Center"
                                                                        Margin="0,0,8,0">
                                                                    <TextBlock Text="笔记" TextWrapping="NoWrap" VerticalAlignment="Center"/>
                                                                </Button>
                                                                <Button Command="{Binding DataContext.QuickCompleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding Id}"
                                                                        Style="{StaticResource SecondaryButton}"
                                                                        Width="100"
                                                                        Height="36"
                                                                        VerticalContentAlignment="Center">
                                                                    <TextBlock Text="快速完成" TextWrapping="NoWrap" VerticalAlignment="Center"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>

                        <!-- 待办列表页面 -->
                        <DataTemplate DataType="{x:Type viewModels:TodoViewModel}">
                            <StackPanel>
                                <TextBlock Text="待办列表"
                                           Style="{StaticResource HeadingTextBlock}"/>
                                <TextBlock Text="管理你的待办事项"
                                           Style="{StaticResource SubheadingTextBlock}"/>
                                <TextBox Text="{Binding InputContent, UpdateSourceTrigger=PropertyChanged}"
                                         KeyDown="OnKeyDown"
                                         Margin="0,0,0,10"/>
                                <Button Content="添加待办"
                                        Command="{Binding AddTodoCommand}"
                                        Height="44"
                                        Width="120"
                                        HorizontalAlignment="Left"/>
                                <ItemsControl ItemsSource="{Binding Todos}" Margin="0,20,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardBorder}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Content}"
                                                               TextWrapping="Wrap"
                                                               FontSize="{StaticResource FontSizeMedium}"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,10,0"/>
                                                    <Button Grid.Column="1"
                                                            Content="删除"
                                                            Command="{Binding DataContext.DeleteTodoCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding Id}"
                                                            Style="{StaticResource DeleteButton}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>

                        <!-- 今日待办页面 -->
                        <DataTemplate DataType="{x:Type viewModels:TodayViewModel}">
                            <StackPanel>
                                <TextBlock Text="今日待办"
                                           Style="{StaticResource HeadingTextBlock}"/>
                                <TextBlock Text="今天要做的1-3件事"
                                           Style="{StaticResource SubheadingTextBlock}"/>
                                <TextBox Text="{Binding InputContent, UpdateSourceTrigger=PropertyChanged}"
                                         KeyDown="OnKeyDown"
                                         Margin="0,0,0,10"/>
                                <Button Content="添加任务"
                                        Command="{Binding AddTaskCommand}"
                                        Height="44"
                                        Width="120"
                                        HorizontalAlignment="Left"/>
                                <ItemsControl ItemsSource="{Binding TodayTasks}" Margin="0,20,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardBorder}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Content}"
                                                               TextWrapping="Wrap"
                                                               FontSize="{StaticResource FontSizeMedium}"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,10,0"/>
                                                    <Button Grid.Column="1"
                                                            Content="删除"
                                                            Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding Id}"
                                                            Style="{StaticResource DeleteButton}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>

                        <!-- 笔记库页面 -->
                        <DataTemplate DataType="{x:Type viewModels:NotesViewModel}">
                            <StackPanel>
                                <TextBlock Text="笔记库"
                                           Style="{StaticResource HeadingTextBlock}"/>
                                <TextBlock Text="记录你的想法和笔记"
                                           Style="{StaticResource SubheadingTextBlock}"/>
                                <TextBox Text="{Binding InputContent, UpdateSourceTrigger=PropertyChanged}"
                                         KeyDown="OnKeyDown"
                                         Margin="0,0,0,10"/>
                                <Button Content="添加笔记"
                                        Command="{Binding AddNoteCommand}"
                                        Height="44"
                                        Width="120"
                                        HorizontalAlignment="Left"/>
                                <ItemsControl ItemsSource="{Binding Notes}" Margin="0,20,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardBorder}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Content}"
                                                               TextWrapping="Wrap"
                                                               FontSize="{StaticResource FontSizeMedium}"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,10,0"/>
                                                    <Button Grid.Column="1"
                                                            Content="删除"
                                                            Command="{Binding DataContext.DeleteNoteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding Id}"
                                                            Style="{StaticResource DeleteButton}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>

                        <!-- 每周回顾页面 -->
                        <DataTemplate DataType="{x:Type viewModels:WeeklyReviewViewModel}">
                            <StackPanel>
                                <TextBlock Text="每周回顾"
                                           Style="{StaticResource HeadingTextBlock}"/>
                                <TextBlock Text="回顾本周完成的工作"
                                           Style="{StaticResource SubheadingTextBlock}"/>
                                <Button Content="刷新数据"
                                        Command="{Binding RefreshDataCommand}"
                                        Height="44"
                                        Width="120"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,20"/>
                                <ItemsControl>
                                    <ItemsControl.Items>
                                        <!-- 统计卡片 -->
                                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="本周完成"
                                                           FontSize="{StaticResource FontSizeLarge}"
                                                           FontWeight="Bold"
                                                           Margin="0,0,0,5"/>
                                                <TextBlock Text="{Binding CompletedTasksCount, StringFormat={}{0} 个想法}"
                                                           FontSize="{StaticResource FontSizeTitle}"
                                                           Foreground="{StaticResource BrandOrange}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="番茄钟统计"
                                                           FontSize="{StaticResource FontSizeLarge}"
                                                           FontWeight="Bold"
                                                           Margin="0,0,0,5"/>
                                                <TextBlock Text="{Binding TotalPomodoroTime}"
                                                           FontSize="{StaticResource FontSizeTitle}"
                                                           Foreground="{StaticResource BrandOrange}"/>
                                            </StackPanel>
                                        </Border>
                                    </ItemsControl.Items>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
