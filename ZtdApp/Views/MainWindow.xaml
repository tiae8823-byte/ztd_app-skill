<Window x:Class="ZtdApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:ZtdApp.ViewModels.Pages"
        xmlns:system="clr-namespace:System;assembly=System.Runtime"
        Style="{StaticResource MainWindowStyle}"
        Title="ZTD - 我的生产力工具"
        Width="1000"
        Height="700"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 侧边栏 -->
        <Border Grid.Column="0" Style="{StaticResource SidebarBorder}">
            <StackPanel Margin="0,20,0,0">
                <!-- Logo / 标题 -->
                <TextBlock Text="ZTD"
                           FontSize="{StaticResource FontSizeHeading}"
                           FontWeight="Bold"
                           Margin="0,0,0,30"
                           HorizontalAlignment="Center"/>

                <!-- 导航按钮 -->
                <Button Content="想法收集"
                        Command="{Binding NavigateToIdeasCommand}"
                        Style="{StaticResource NavButton}"/>
                <Button Content="待办列表"
                        Command="{Binding NavigateToTodosCommand}"
                        Style="{StaticResource NavButton}"/>
                <Button Content="今日待办"
                        Command="{Binding NavigateToTodayCommand}"
                        Style="{StaticResource NavButton}"/>
                <Button Content="笔记库"
                        Command="{Binding NavigateToNotesCommand}"
                        Style="{StaticResource NavButton}"/>
                <Button Content="每周回顾"
                        Command="{Binding NavigateToReviewCommand}"
                        Style="{StaticResource NavButton}"/>
                <Button Content="测试界面"
                        Command="{Binding NavigateToTestCommand}"
                        Style="{StaticResource NavButton}"/>
            </StackPanel>
        </Border>

        <!-- 内容区域 -->
        <Border Grid.Column="1" Background="{StaticResource BrandLight}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                <ContentControl Content="{Binding CurrentPage}">
                    <ContentControl.Resources>
                        <!-- 想法收集页面 -->
                        <DataTemplate DataType="{x:Type viewModels:IdeaViewModel}">
                            <StackPanel>
                                <TextBlock Text="想法收集"
                                           Style="{StaticResource PageTitleTextBlock}"/>
                                <TextBlock Text="快速记录你的想法"
                                           Style="{StaticResource PageDescriptionTextBlock}"/>
                                <Grid>
                                    <TextBox Text="{Binding InputContent, UpdateSourceTrigger=PropertyChanged}"
                                             KeyDown="OnKeyDown"
                                             Height="166"
                                             Margin="157,0,157,0"/>
                                    <Button Content="添加想法"
                                            Command="{Binding AddIdeaCommand}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Bottom"
                                            Margin="165,0,0,8"
                                            Padding="8,4"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding Ideas}" Margin="0,20,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardBorder}" Cursor="Hand">
                                                <StackPanel>
                                                    <!-- 卡片头部：内容 + 删除按钮 -->
                                                    <Grid>
                                                        <Grid.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                                                                        Command="{Binding DataContext.ToggleExpandCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}"/>
                                                        </Grid.InputBindings>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                            <TextBlock Text="{Binding Content}"
                                                                       Style="{StaticResource CardContentTextBlock}"
                                                                       Margin="0,0,0,4"/>
                                                            <TextBlock Text="{Binding CreatedAtDisplay}"
                                                                       Style="{StaticResource CardDateTextBlock}"
                                                                       Opacity="0.8"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="1"
                                                                Content="删除"
                                                                Command="{Binding DataContext.DeleteIdeaCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding Id}"
                                                                Style="{StaticResource CardDeleteButtonHover}"/>
                                                    </Grid>

                                                    <!-- 操作按钮区域（展开且未选标签时显示） -->
                                                    <StackPanel Visibility="{Binding IsShowingActions, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                Margin="0,10,0,0">
                                                        <Border BorderBrush="{StaticResource BrandLightGray}"
                                                                BorderThickness="0,1,0,0"
                                                                Padding="0,10,0,0">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Button Command="{Binding DataContext.StartTagSelectionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding Id}"
                                                                        Style="{StaticResource IdeaActionButton}"
                                                                        Content="待办"/>
                                                                <Button Command="{Binding DataContext.ConvertToNoteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding Id}"
                                                                        Style="{StaticResource IdeaActionButton}"
                                                                        Content="笔记"/>
                                                                <Button Command="{Binding DataContext.QuickCompleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding Id}"
                                                                        Style="{StaticResource IdeaActionButton}"
                                                                        Content="快速完成"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>

                                                    <!-- 标签选择面板（点击待办后显示） -->
                                                    <StackPanel Visibility="{Binding IsSelectingTags, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                Margin="0,10,0,0">
                                                        <Border BorderBrush="{StaticResource BrandLightGray}"
                                                                BorderThickness="0,1,0,0"
                                                                Padding="0,10,0,0">
                                                            <StackPanel>
                                                                <!-- 时间标签卡片（必选） -->
                                                                <Border Background="#d4d2c8"
                                                                        CornerRadius="6"
                                                                        Padding="12,10"
                                                                        Margin="0,0,0,8">
                                                                    <StackPanel>
                                                                        <TextBlock Text="时间标签（必选）"
                                                                                   FontSize="{StaticResource FontSizeSmall}"
                                                                                   Foreground="{StaticResource BrandDark}"
                                                                                   Margin="0,0,0,8"/>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <RadioButton Content="&lt;30分钟"
                                                                                         IsChecked="{Binding IsShortTime}"
                                                                                         GroupName="{Binding Id}"
                                                                                         Margin="0,0,16,0"
                                                                                         VerticalContentAlignment="Center"/>
                                                                            <RadioButton Content="&gt;30分钟"
                                                                                         IsChecked="{Binding IsLongTime}"
                                                                                         GroupName="{Binding Id}"
                                                                                         VerticalContentAlignment="Center"/>
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </Border>

                                                                <!-- 分类标签卡片（可选） -->
                                                                <Border Background="#d4d2c8"
                                                                        CornerRadius="6"
                                                                        Padding="12,10"
                                                                        Margin="0,0,0,12">
                                                                    <StackPanel>
                                                                        <TextBlock Text="分类标签（可选）"
                                                                                   FontSize="{StaticResource FontSizeSmall}"
                                                                                   Foreground="{StaticResource BrandDark}"
                                                                                   Margin="0,0,0,8"/>
                                                                        <ComboBox SelectedItem="{Binding SelectedCategoryTag}"
                                                                                  Width="120"
                                                                                  HorizontalAlignment="Left">
                                                                            <ComboBox.Items>
                                                                                <system:String>工作</system:String>
                                                                                <system:String>个人</system:String>
                                                                                <system:String>学习</system:String>
                                                                                <system:String>运动</system:String>
                                                                            </ComboBox.Items>
                                                                        </ComboBox>
                                                                    </StackPanel>
                                                                </Border>

                                                                <!-- 确认按钮 -->
                                                                <Button Content="✓ 确认转为待办"
                                                                        Command="{Binding DataContext.ConfirmTagSelectionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding Id}"
                                                                        MaxWidth="300"
                                                                        HorizontalAlignment="Left"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>

                        <!-- 待办列表页面 -->
                        <DataTemplate DataType="{x:Type viewModels:TodoViewModel}">
                            <DockPanel LastChildFill="True">
                                <!-- 底部批量操作栏（有勾选时显示） -->
                                <Border DockPanel.Dock="Bottom"
                                        Background="{StaticResource BrandLight}"
                                        BorderBrush="{StaticResource BrandLightGray}"
                                        BorderThickness="0,1,0,0"
                                        Padding="16"
                                        Visibility="{Binding HasCheckedTasks, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button Content="{Binding BatchCompleteText}"
                                            Command="{Binding BatchCompleteCommand}"
                                            HorizontalAlignment="Left"
                                            Width="180"/>
                                </Border>

                                <!-- 主内容区 -->
                                <StackPanel>
                                    <!-- 标题（居中） -->
                                    <TextBlock Text="待办列表"
                                               Style="{StaticResource PageTitleTextBlock}"/>
                                    <TextBlock Text="在想法中点击「待办」将想法转为任务"
                                               Style="{StaticResource PageDescriptionTextBlock}"/>

                                    <!-- 筛选栏（两排居中） -->
                                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                                        <!-- 第一排：时间筛选 -->
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                                            <Button Content="&lt;30分钟"
                                                    Command="{Binding ToggleTimeFilterCommand}"
                                                    CommandParameter="&lt;30分钟"
                                                    Margin="0,0,6,0">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource FilterChipButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedTimeFilter}" Value="&lt;30分钟">
                                                                <Setter Property="Background" Value="{StaticResource BrandOrange}"/>
                                                                <Setter Property="Foreground" Value="{StaticResource BrandLight}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Content="&gt;30分钟"
                                                    Command="{Binding ToggleTimeFilterCommand}"
                                                    CommandParameter="&gt;30分钟"
                                                    Margin="0">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource FilterChipButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedTimeFilter}" Value="&gt;30分钟">
                                                                <Setter Property="Background" Value="{StaticResource BrandOrange}"/>
                                                                <Setter Property="Foreground" Value="{StaticResource BrandLight}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                        <!-- 第二排：分类筛选 -->
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="工作"
                                                    Command="{Binding ToggleCategoryFilterCommand}"
                                                    CommandParameter="工作"
                                                    Margin="0,0,6,0">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource FilterChipButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedCategoryFilter}" Value="工作">
                                                                <Setter Property="Background" Value="{StaticResource BrandOrange}"/>
                                                                <Setter Property="Foreground" Value="{StaticResource BrandLight}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Content="个人"
                                                    Command="{Binding ToggleCategoryFilterCommand}"
                                                    CommandParameter="个人"
                                                    Margin="0,0,6,0">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource FilterChipButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedCategoryFilter}" Value="个人">
                                                                <Setter Property="Background" Value="{StaticResource BrandOrange}"/>
                                                                <Setter Property="Foreground" Value="{StaticResource BrandLight}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Content="学习"
                                                    Command="{Binding ToggleCategoryFilterCommand}"
                                                    CommandParameter="学习"
                                                    Margin="0,0,6,0">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource FilterChipButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedCategoryFilter}" Value="学习">
                                                                <Setter Property="Background" Value="{StaticResource BrandOrange}"/>
                                                                <Setter Property="Foreground" Value="{StaticResource BrandLight}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Content="运动"
                                                    Command="{Binding ToggleCategoryFilterCommand}"
                                                    CommandParameter="运动"
                                                    Margin="0">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource FilterChipButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedCategoryFilter}" Value="运动">
                                                                <Setter Property="Background" Value="{StaticResource BrandOrange}"/>
                                                                <Setter Property="Foreground" Value="{StaticResource BrandLight}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- <30分钟 分组 -->
                                    <StackPanel Visibility="{Binding HasShortTimeTasks, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Style="{StaticResource GroupHeaderTextBlock}" Margin="157,0,157,0">
                                            <Run Text="&lt;30分钟"/>
                                            <Run Text=" ("/>
                                            <Run Text="{Binding ShortTimeCount, Mode=OneWay}"/>
                                            <Run Text=")"/>
                                        </TextBlock>
                                        <ItemsControl ItemsSource="{Binding ShortTimeTasks}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource CardBorder}" Cursor="Hand">
                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                                                                          Command="{Binding DataContext.ToggleTaskExpandCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                          CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                        <StackPanel>
                                                            <!-- 卡片头部：复选框 + 内容 + 右侧元信息 -->
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <!-- 复选框 -->
                                                                <CheckBox Grid.Column="0"
                                                                          IsChecked="{Binding IsChecked}"
                                                                          VerticalAlignment="Center"
                                                                          Margin="0,0,12,0"
                                                                          Click="OnCheckBoxClick"/>
                                                                <!-- 任务内容 -->
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Content}"
                                                                           Style="{StaticResource CardContentTextBlock}"
                                                                           VerticalAlignment="Center"/>
                                                                <!-- 右侧元信息 -->
                                                                <StackPanel Grid.Column="2"
                                                                            Orientation="Vertical"
                                                                            HorizontalAlignment="Right"
                                                                            VerticalAlignment="Center"
                                                                            Margin="12,0,0,0">
                                                                    <TextBlock Text="{Binding CategoryTagDisplay}"
                                                                               Style="{StaticResource CardTagTextBlock}"
                                                                               HorizontalAlignment="Right"/>
                                                                    <TextBlock Text="{Binding CreatedAtDisplay}"
                                                                               Style="{StaticResource CardDateTextBlock}"
                                                                               HorizontalAlignment="Right"/>
                                                                </StackPanel>
                                                            </Grid>

                                                            <!-- 展开操作区域（卡片内部） -->
                                                            <Border x:Name="ExpandPanel"
                                                                    BorderBrush="{StaticResource BrandLightGray}"
                                                                    BorderThickness="0,1,0,0"
                                                                    Margin="0,12,0,0"
                                                                    Padding="0,12,0,0"
                                                                    Opacity="0"
                                                                    Height="0"
                                                                    ClipToBounds="True">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                                <DataTrigger.EnterActions>
                                                                                    <BeginStoryboard>
                                                                                        <Storyboard>
                                                                                            <DoubleAnimation Storyboard.TargetProperty="Height"
                                                                                                             From="0" To="56"
                                                                                                             Duration="0:0:0.25">
                                                                                                <DoubleAnimation.EasingFunction>
                                                                                                    <CubicEase EasingMode="EaseOut"/>
                                                                                                </DoubleAnimation.EasingFunction>
                                                                                            </DoubleAnimation>
                                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                             From="0" To="1"
                                                                                                             Duration="0:0:0.2">
                                                                                                <DoubleAnimation.EasingFunction>
                                                                                                    <CubicEase EasingMode="EaseOut"/>
                                                                                                </DoubleAnimation.EasingFunction>
                                                                                            </DoubleAnimation>
                                                                                        </Storyboard>
                                                                                    </BeginStoryboard>
                                                                                </DataTrigger.EnterActions>
                                                                                <DataTrigger.ExitActions>
                                                                                    <BeginStoryboard>
                                                                                        <Storyboard>
                                                                                            <DoubleAnimation Storyboard.TargetProperty="Height"
                                                                                                             From="56" To="0"
                                                                                                             Duration="0:0:0.2">
                                                                                                <DoubleAnimation.EasingFunction>
                                                                                                    <CubicEase EasingMode="EaseIn"/>
                                                                                                </DoubleAnimation.EasingFunction>
                                                                                            </DoubleAnimation>
                                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                             From="1" To="0"
                                                                                                             Duration="0:0:0.15">
                                                                                                <DoubleAnimation.EasingFunction>
                                                                                                    <CubicEase EasingMode="EaseIn"/>
                                                                                                </DoubleAnimation.EasingFunction>
                                                                                            </DoubleAnimation>
                                                                                        </Storyboard>
                                                                                    </BeginStoryboard>
                                                                                </DataTrigger.ExitActions>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Button Content="完成"
                                                                            Command="{Binding DataContext.CompleteTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                            CommandParameter="{Binding Id}"
                                                                            Style="{StaticResource CardActionButton}"/>
                                                                    <Button Content="删除"
                                                                            Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                            CommandParameter="{Binding Id}"
                                                                            Style="{StaticResource CardDeleteButton}"
                                                                            Margin="8,0,0,0"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!-- >30分钟 分组 -->
                                    <StackPanel Visibility="{Binding HasLongTimeTasks, Converter={StaticResource BoolToVisibilityConverter}}"
                                                Margin="0,16,0,0">
                                        <TextBlock Style="{StaticResource GroupHeaderTextBlock}" Margin="157,0,157,0">
                                            <Run Text="&gt;30分钟"/>
                                            <Run Text=" ("/>
                                            <Run Text="{Binding LongTimeCount, Mode=OneWay}"/>
                                            <Run Text=")"/>
                                        </TextBlock>
                                        <ItemsControl ItemsSource="{Binding LongTimeTasks}" Margin="0,8,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource CardBorder}" Cursor="Hand">
                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                                                                          Command="{Binding DataContext.ToggleTaskExpandCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                          CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                        <StackPanel>
                                                            <!-- 卡片头部：内容 + 右侧元信息 -->
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <!-- 任务内容 -->
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{Binding Content}"
                                                                           Style="{StaticResource CardContentTextBlock}"
                                                                           VerticalAlignment="Center"/>
                                                                <!-- 右侧元信息 -->
                                                                <StackPanel Grid.Column="1"
                                                                            Orientation="Vertical"
                                                                            HorizontalAlignment="Right"
                                                                            VerticalAlignment="Center"
                                                                            Margin="12,0,0,0">
                                                                    <TextBlock Text="{Binding CategoryTagDisplay}"
                                                                               Style="{StaticResource CardTagTextBlock}"
                                                                               HorizontalAlignment="Right"/>
                                                                    <TextBlock Text="{Binding CreatedAtDisplay}"
                                                                               Style="{StaticResource CardDateTextBlock}"
                                                                               HorizontalAlignment="Right"/>
                                                                </StackPanel>
                                                            </Grid>

                                                            <!-- 展开操作区域（卡片内部） -->
                                                            <Border x:Name="ExpandPanel"
                                                                    BorderBrush="{StaticResource BrandLightGray}"
                                                                    BorderThickness="0,1,0,0"
                                                                    Margin="0,12,0,0"
                                                                    Padding="0,12,0,0"
                                                                    Opacity="0"
                                                                    Height="0"
                                                                    ClipToBounds="True">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                                <DataTrigger.EnterActions>
                                                                                    <BeginStoryboard>
                                                                                        <Storyboard>
                                                                                            <DoubleAnimation Storyboard.TargetProperty="Height"
                                                                                                             From="0" To="56"
                                                                                                             Duration="0:0:0.25">
                                                                                                <DoubleAnimation.EasingFunction>
                                                                                                    <CubicEase EasingMode="EaseOut"/>
                                                                                                </DoubleAnimation.EasingFunction>
                                                                                            </DoubleAnimation>
                                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                             From="0" To="1"
                                                                                                             Duration="0:0:0.2">
                                                                                                <DoubleAnimation.EasingFunction>
                                                                                                    <CubicEase EasingMode="EaseOut"/>
                                                                                                </DoubleAnimation.EasingFunction>
                                                                                            </DoubleAnimation>
                                                                                        </Storyboard>
                                                                                    </BeginStoryboard>
                                                                                </DataTrigger.EnterActions>
                                                                                <DataTrigger.ExitActions>
                                                                                    <BeginStoryboard>
                                                                                        <Storyboard>
                                                                                            <DoubleAnimation Storyboard.TargetProperty="Height"
                                                                                                             From="56" To="0"
                                                                                                             Duration="0:0:0.2">
                                                                                                <DoubleAnimation.EasingFunction>
                                                                                                    <CubicEase EasingMode="EaseIn"/>
                                                                                                </DoubleAnimation.EasingFunction>
                                                                                            </DoubleAnimation>
                                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                             From="1" To="0"
                                                                                                             Duration="0:0:0.15">
                                                                                                <DoubleAnimation.EasingFunction>
                                                                                                    <CubicEase EasingMode="EaseIn"/>
                                                                                                </DoubleAnimation.EasingFunction>
                                                                                            </DoubleAnimation>
                                                                                        </Storyboard>
                                                                                    </BeginStoryboard>
                                                                                </DataTrigger.ExitActions>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Button Content="加入今日"
                                                                            Command="{Binding DataContext.MoveToTodayCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                            CommandParameter="{Binding Id}"
                                                                            Style="{StaticResource CardActionButton}"/>
                                                                    <Button Content="删除"
                                                                            Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                            CommandParameter="{Binding Id}"
                                                                            Style="{StaticResource CardDeleteButton}"
                                                                            Margin="8,0,0,0"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!-- 空状态提示 -->
                                    <TextBlock Text="暂无待办任务"
                                               FontSize="{StaticResource FontSizeBody}"
                                               Foreground="{StaticResource BrandMidGray}"
                                               HorizontalAlignment="Center"
                                               Margin="0,40,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasAnyTasks}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>

                        <!-- 今日待办页面 -->
                        <DataTemplate DataType="{x:Type viewModels:TodayViewModel}">
                            <Grid>
                                <StackPanel>
                                <TextBlock Text="今日待办"
                                           Style="{StaticResource PageTitleTextBlock}"/>
                                <TextBlock Style="{StaticResource PageDescriptionTextBlock}">
                                    <Run Text="今天要做的 1-3 件事"/>
                                    <Run Text=" ("/>
                                    <Run Text="{Binding TodayTaskCount, Mode=OneWay}"/>
                                    <Run Text="/"/>
                                    <Run Text="{Binding MaxTasks, Mode=OneWay}"/>
                                    <Run Text=")"/>
                                </TextBlock>

                                <!-- 任务列表 -->
                                <ItemsControl ItemsSource="{Binding TodayTasks}" Margin="0,10,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardBorder}">
                                                <StackPanel>
                                                    <!-- 任务头部：内容 + 番茄钟按钮 -->
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Task.Content}"
                                                                   TextWrapping="Wrap"
                                                                   FontSize="{StaticResource FontSizeMedium}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,10,0"/>
                                                        <!-- 番茄钟按钮（展开/收起） -->
                                                        <Button Grid.Column="1"
                                                                Content="{Binding TimerDisplay}"
                                                                Command="{Binding DataContext.StartTomatoCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding Task.Id}"
                                                                FontSize="{StaticResource FontSizeMedium}"
                                                                FontWeight="Bold"
                                                                Padding="12,6"
                                                                MinWidth="70">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                                    <Style.Triggers>
                                                                        <!-- 计时中状态：橙色 -->
                                                                        <DataTrigger Binding="{Binding IsTomatoRunning}" Value="True">
                                                                            <Setter Property="Background" Value="{StaticResource BrandOrange}"/>
                                                                        </DataTrigger>
                                                                        <!-- 暂停状态：灰色 -->
                                                                        <DataTrigger Binding="{Binding IsTomatoPaused}" Value="True">
                                                                            <Setter Property="Background" Value="{StaticResource BrandMidGray}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </Grid>

                                                    <!-- 番茄钟控制面板（计时中或暂停时显示） -->
                                                    <StackPanel Visibility="{Binding IsTomatoRunning, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                Margin="0,12,0,0">
                                                        <Border BorderBrush="{StaticResource BrandLightGray}"
                                                                BorderThickness="0,1,0,0"
                                                                Padding="0,12,0,0">
                                                            <StackPanel Orientation="Horizontal">
                                                                <!-- 计时器显示 -->
                                                                <TextBlock Text="{Binding TimerDisplay}"
                                                                           FontSize="24"
                                                                           FontWeight="Bold"
                                                                           Foreground="{StaticResource BrandOrange}"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,16,0"/>
                                                                <!-- 暂停按钮 -->
                                                                <Button Content="暂停"
                                                                        Command="{Binding DataContext.PauseTomatoCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding Task.Id}"
                                                                        Style="{StaticResource CardActionButton}"
                                                                        Margin="0,0,6,0"/>
                                                                <!-- 放弃按钮 -->
                                                                <Button Content="放弃"
                                                                        Command="{Binding DataContext.AbandonTomatoCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding Task.Id}"
                                                                        Style="{StaticResource CardDeleteButton}"
                                                                        Margin="0,0,6,0"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>

                                                    <!-- 暂停状态面板 -->
                                                    <StackPanel Visibility="{Binding IsTomatoPaused, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                Margin="0,12,0,0">
                                                        <Border BorderBrush="{StaticResource BrandLightGray}"
                                                                BorderThickness="0,1,0,0"
                                                                Padding="0,12,0,0">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding TimerDisplay}"
                                                                           FontSize="24"
                                                                           FontWeight="Bold"
                                                                           Foreground="{StaticResource BrandMidGray}"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,16,0"/>
                                                                <TextBlock Text="已暂停"
                                                                           FontSize="{StaticResource FontSizeCaption}"
                                                                           Foreground="{StaticResource BrandMidGray}"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,16,0"/>
                                                                <Button Content="继续"
                                                                        Command="{Binding DataContext.StartTomatoCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding Task.Id}"
                                                                        Style="{StaticResource CardActionButton}"
                                                                        Margin="0,0,6,0"/>
                                                                <Button Content="放弃"
                                                                        Command="{Binding DataContext.AbandonTomatoCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding Task.Id}"
                                                                        Style="{StaticResource CardDeleteButton}"
                                                                        Margin="0,0,6,0"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>

                                                    <!-- 操作按钮行 -->
                                                    <Border BorderBrush="{StaticResource BrandLightGray}"
                                                            BorderThickness="0,1,0,0"
                                                            Padding="0,10,0,0"
                                                            Margin="0,10,0,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Content="完成"
                                                                    Command="{Binding DataContext.CompleteTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding Task.Id}"
                                                                    Style="{StaticResource CardActionButton}"
                                                                    Margin="0,0,6,0"/>
                                                            <Button Content="退回待办"
                                                                    Command="{Binding DataContext.MoveBackToTodoCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding Task.Id}"
                                                                    Style="{StaticResource CardDeleteButton}"
                                                                    Margin="0"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- 空状态提示 -->
                                <TextBlock Text="从待办列表选择 >30分钟 的任务加入"
                                           FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{StaticResource BrandMidGray}"
                                           HorizontalAlignment="Center"
                                           Margin="0,40,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TodayTaskCount}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <!-- 自定义时长对话框 -->
                            <Grid Visibility="{Binding IsDialogVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                  Background="#80000000">
                                <Border Style="{StaticResource CardBorder}"
                                        Width="400"
                                        Padding="24"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                    <StackPanel>
                                        <TextBlock Text="设置番茄钟时长"
                                                   Style="{StaticResource PageTitleTextBlock}"
                                                   Margin="0,0,0,20"/>

                                        <!-- 预设时长按钮 -->
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    Margin="0,0,0,16">
                                            <Button Content="15分钟"
                                                    Command="{Binding SelectPresetCommand}"
                                                    CommandParameter="15"
                                                    Width="72"
                                                    Margin="0,0,6,0">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource FilterChipButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedPresetMinutes}" Value="15">
                                                                <Setter Property="Background" Value="{StaticResource BrandOrange}"/>
                                                                <Setter Property="Foreground" Value="{StaticResource BrandLight}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Content="25分钟"
                                                    Command="{Binding SelectPresetCommand}"
                                                    CommandParameter="25"
                                                    Width="72"
                                                    Margin="0,0,6,0">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource FilterChipButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedPresetMinutes}" Value="25">
                                                                <Setter Property="Background" Value="{StaticResource BrandOrange}"/>
                                                                <Setter Property="Foreground" Value="{StaticResource BrandLight}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Content="45分钟"
                                                    Command="{Binding SelectPresetCommand}"
                                                    CommandParameter="45"
                                                    Width="72"
                                                    Margin="0,0,6,0">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource FilterChipButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedPresetMinutes}" Value="45">
                                                                <Setter Property="Background" Value="{StaticResource BrandOrange}"/>
                                                                <Setter Property="Foreground" Value="{StaticResource BrandLight}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Content="60分钟"
                                                    Command="{Binding SelectPresetCommand}"
                                                    CommandParameter="60"
                                                    Width="72"
                                                    Margin="0,0,6,0">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource FilterChipButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedPresetMinutes}" Value="60">
                                                                <Setter Property="Background" Value="{StaticResource BrandOrange}"/>
                                                                <Setter Property="Foreground" Value="{StaticResource BrandLight}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>

                                        <!-- 自定义输入：分钟 + 秒 -->
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    Margin="0,0,0,20">
                                            <TextBlock Text="自定义:"
                                                       FontSize="{StaticResource FontSizeMedium}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                                            <TextBox Text="{Binding CustomMinutesInput, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="60"
                                                     Padding="8,6"
                                                     Margin="0,0,4,0"/>
                                            <TextBlock Text="分"
                                                       FontSize="{StaticResource FontSizeMedium}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                                            <TextBox Text="{Binding CustomSecondsInput, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="60"
                                                     Padding="8,6"
                                                     Margin="0,0,4,0"/>
                                            <TextBlock Text="秒"
                                                       FontSize="{StaticResource FontSizeMedium}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- 操作按钮 -->
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center">
                                            <Button Content="开始"
                                                    Command="{Binding ConfirmStartTomatoCommand}"
                                                    Width="100"
                                                    Margin="5"
                                                    Padding="16,8"
                                                    FontSize="{StaticResource FontSizeMedium}"
                                                    FontWeight="SemiBold"
                                                    VerticalContentAlignment="Center"
                                                    HorizontalAlignment="Left"/>
                                            <Button Content="取消"
                                                    Command="{Binding CancelDialogCommand}"
                                                    Style="{StaticResource DeleteButton}"
                                                    Width="100"
                                                    Margin="5"
                                                    Padding="16,8"
                                                    FontSize="{StaticResource FontSizeMedium}"
                                                    FontWeight="SemiBold"
                                                    VerticalContentAlignment="Center"
                                                    HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            </Grid>
                        </DataTemplate>

                        <!-- 笔记库页面 -->
                        <DataTemplate DataType="{x:Type viewModels:NotesViewModel}">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="笔记库"
                                               Style="{StaticResource PageTitleTextBlock}"/>
                                    <TextBlock Text="记录你的想法和笔记"
                                               Style="{StaticResource PageDescriptionTextBlock}"/>

                                    <!-- 输入区域 -->
                                    <TextBox Text="{Binding InputContent, UpdateSourceTrigger=PropertyChanged}"
                                             KeyDown="OnKeyDown"
                                             Margin="157,0,157,10"/>

                                    <!-- 分类选择 + 添加按钮 -->
                                    <StackPanel Orientation="Horizontal" Margin="157,0,157,20">
                                        <ComboBox ItemsSource="{Binding Categories}"
                                                  SelectedItem="{Binding SelectedCategory}"
                                                  Width="120"
                                                  Margin="0,0,10,0">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <Button Content="添加笔记"
                                                Command="{Binding AddNoteCommand}"
                                                Height="44"
                                                Width="120"/>
                                    </StackPanel>

                                    <!-- 笔记列表 -->
                                    <ItemsControl ItemsSource="{Binding Notes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource CardBorder}" Cursor="Hand">
                                                    <Grid>
                                                        <Grid.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                                                                        Command="{Binding DataContext.OpenEditDialogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding Id}"/>
                                                        </Grid.InputBindings>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <!-- 笔记内容 -->
                                                        <TextBlock Grid.Row="0"
                                                                   Text="{Binding Content}"
                                                                   Style="{StaticResource CardContentTextBlock}"
                                                                   Margin="0,0,0,8"/>

                                                        <!-- 底部：分类标签 + 时间 + 操作按钮 -->
                                                        <Grid Grid.Row="1">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- 左侧：分类 + 时间 -->
                                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                                <TextBlock Text="{Binding Category, StringFormat=[{0}]}"
                                                                           Margin="0,0,10,0">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource CardTagTextBlock}">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Category}" Value="{x:Null}">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock Text="{Binding CreatedAtDisplay}"
                                                                           Style="{StaticResource CardDateTextBlock}"/>
                                                            </StackPanel>

                                                            <!-- 右侧：操作按钮 -->
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                <Button Content="编辑"
                                                                        Command="{Binding DataContext.OpenEditDialogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding Id}"
                                                                        Style="{StaticResource CardActionButtonHover}"
                                                                        Margin="0,0,4,0"/>
                                                                <Button Content="删除"
                                                                        Command="{Binding DataContext.DeleteNoteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding Id}"
                                                                        Style="{StaticResource CardDeleteButtonHover}"
                                                                        Margin="4,0,0,0"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- 编辑对话框 -->
                                <Grid Visibility="{Binding IsEditDialogVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                      Background="#80000000">
                                    <Border Background="{StaticResource BrandLight}"
                                            BorderBrush="{StaticResource BrandLightGray}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Width="400"
                                            Padding="20"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center">
                                        <StackPanel>
                                            <TextBlock Text="编辑笔记"
                                                       FontSize="{StaticResource FontSizeLarge}"
                                                       FontWeight="Bold"
                                                       Margin="0,0,0,15"/>

                                            <!-- 笔记内容 -->
                                            <TextBox Text="{Binding EditContent, UpdateSourceTrigger=PropertyChanged}"
                                                     TextWrapping="Wrap"
                                                     AcceptsReturn="True"
                                                     MinHeight="100"
                                                     Margin="0,0,0,15"/>

                                            <!-- 分类选择 -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                                <TextBlock Text="分类:"
                                                           FontSize="{StaticResource FontSizeMedium}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,10,0"/>
                                                <ComboBox ItemsSource="{Binding Categories}"
                                                          SelectedItem="{Binding EditCategory}"
                                                          Width="150">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>

                                            <!-- 按钮 -->
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <Button Content="保存"
                                                        Command="{Binding SaveEditCommand}"
                                                        Width="100"
                                                        Margin="5"
                                                        Padding="16,8"
                                                        FontSize="{StaticResource FontSizeMedium}"
                                                        FontWeight="SemiBold"
                                                        VerticalContentAlignment="Center"
                                                        HorizontalAlignment="Left"/>
                                                <Button Content="取消"
                                                        Command="{Binding CancelEditCommand}"
                                                        Style="{StaticResource DeleteButton}"
                                                        Width="100"
                                                        Margin="5"
                                                        Padding="16,8"
                                                        FontSize="{StaticResource FontSizeMedium}"
                                                        FontWeight="SemiBold"
                                                        VerticalContentAlignment="Center"
                                                        HorizontalAlignment="Left"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </DataTemplate>

                        <!-- 每周回顾页面 -->
                        <DataTemplate DataType="{x:Type viewModels:WeeklyReviewViewModel}">
                            <StackPanel>
                                <TextBlock Text="每周回顾"
                                           Style="{StaticResource PageTitleTextBlock}"/>
                                <TextBlock Text="回顾本周完成的工作"
                                           Style="{StaticResource PageDescriptionTextBlock}"/>
                                <Button Content="刷新数据"
                                        Command="{Binding RefreshDataCommand}"
                                        Height="44"
                                        Width="120"
                                        HorizontalAlignment="Left"
                                        Margin="157,0,157,20"/>

                                <!-- 本周完成任务卡片 -->
                                <Border Style="{StaticResource CardBorder}">
                                    <StackPanel>
                                        <TextBlock Text="本周完成"
                                                   FontSize="{StaticResource FontSizeLarge}"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,5"/>
                                        <TextBlock Text="{Binding CompletedTasksCount, StringFormat={}{0} 个任务}"
                                                   FontSize="{StaticResource FontSizeTitle}"
                                                   Foreground="{StaticResource BrandOrange}"
                                                   Margin="0,0,0,10"/>

                                        <!-- 展开/收起按钮 -->
                                        <Button Command="{Binding ToggleTaskListCommand}"
                                                Style="{StaticResource SecondaryButton}"
                                                Width="100"
                                                HorizontalAlignment="Left"
                                                Margin="0,0,0,10">
                                            <Button.Content>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="展开列表"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsTaskListExpanded}" Value="True">
                                                                    <Setter Property="Text" Value="收起列表"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Button.Content>
                                        </Button>

                                        <!-- 任务列表 -->
                                        <ItemsControl ItemsSource="{Binding CompletedTasks}"
                                                      Visibility="{Binding IsTaskListExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{StaticResource BrandLightGray}"
                                                            BorderThickness="0,1,0,0"
                                                            Padding="0,8,0,0"
                                                            Margin="0,0,0,8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding Content}"
                                                                       Style="{StaticResource CardContentTextBlock}"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding CompletedAtDisplay}"
                                                                       Style="{StaticResource CardDateTextBlock}"
                                                                       Margin="0,0,8,0"/>
                                                            <Button Grid.Column="2"
                                                                    Content="删除"
                                                                    Command="{Binding DataContext.DeleteCompletedTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding Id}"
                                                                    Style="{StaticResource CardDeleteButtonHover}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- 番茄钟统计卡片 -->
                                <Border Style="{StaticResource CardBorder}">
                                    <StackPanel>
                                        <TextBlock Text="番茄钟统计"
                                                   FontSize="{StaticResource FontSizeLarge}"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,5"/>
                                        <TextBlock Text="{Binding TotalPomodoroTime}"
                                                   FontSize="{StaticResource FontSizeTitle}"
                                                   Foreground="{StaticResource BrandOrange}"/>
                                    </StackPanel>
                                </Border>

                                <!-- 本周笔记卡片 -->
                                <Border Style="{StaticResource CardBorder}">
                                    <StackPanel>
                                        <TextBlock Text="本周笔记"
                                                   FontSize="{StaticResource FontSizeLarge}"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,5"/>
                                        <TextBlock Text="{Binding NoteCount, StringFormat={}{0} 条}"
                                                   FontSize="{StaticResource FontSizeTitle}"
                                                   Foreground="{StaticResource BrandOrange}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </DataTemplate>

                        <!-- 测试界面 -->
                        <DataTemplate DataType="{x:Type viewModels:TestViewModel}">
                            <StackPanel>
                                <TextBlock Text="测试界面"
                                           Style="{StaticResource PageTitleTextBlock}"/>
                                <TextBlock Text="在此处测试和设计你的 UI 组件"
                                           Style="{StaticResource PageDescriptionTextBlock}"/>
                                <Grid Margin="157,0,157,0">
                                    <!-- 输入框 -->
                                    <TextBox Text="{Binding InputContent, UpdateSourceTrigger=PropertyChanged}"
                                             KeyDown="OnKeyDown"
                                             Height="166"
                                             FontSize="18"
                                             Padding="10">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                <Style.Resources>
                                                    <VisualBrush x:Key="CueBannerBrush" AlignmentX="Center" AlignmentY="Center" Stretch="None">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="请输入内容..." 
                                                                       Foreground="Gray" 
                                                                       FontSize="16"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Style.Resources>
                                                <Style.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter Property="Background" Value="{StaticResource CueBannerBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding TestCards}" Margin="0,20,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardBorder}" Cursor="Hand">
                                                <Border.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick"
                                                                  Command="{Binding DataContext.ToggleTestCardExpandCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                  CommandParameter="{Binding}"/>
                                                </Border.InputBindings>
                                                <StackPanel>
                                                    <!-- 卡片头部：内容 + 右侧元信息 -->
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <!-- 内容 -->
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Content}"
                                                                   Style="{StaticResource CardContentTextBlock}"
                                                                   VerticalAlignment="Center"/>
                                                        <!-- 右侧元信息 -->
                                                        <StackPanel Grid.Column="1"
                                                                    Orientation="Vertical"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Center"
                                                                    Margin="12,0,0,0">
                                                            <TextBlock Text="{Binding CreatedAtDisplay}"
                                                                       Style="{StaticResource CardDateTextBlock}"
                                                                       HorizontalAlignment="Right"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <!-- 展开操作区域 -->
                                                    <Border x:Name="ExpandPanel"
                                                            BorderBrush="{StaticResource BrandLightGray}"
                                                            BorderThickness="0,1,0,0"
                                                            Margin="0,4,0,0"
                                                            Padding="0,4,0,0"
                                                            Opacity="0"
                                                            Height="0"
                                                            ClipToBounds="True">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                        <DataTrigger.EnterActions>
                                                                            <BeginStoryboard>
                                                                                <Storyboard>
                                                                                    <DoubleAnimation Storyboard.TargetProperty="Height"
                                                                                                     From="0" To="35"
                                                                                                     Duration="0:0:0.25">
                                                                                        <DoubleAnimation.EasingFunction>
                                                                                            <CubicEase EasingMode="EaseOut"/>
                                                                                        </DoubleAnimation.EasingFunction>
                                                                                    </DoubleAnimation>
                                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                     From="0" To="1"
                                                                                                     Duration="0:0:0.2">
                                                                                        <DoubleAnimation.EasingFunction>
                                                                                            <CubicEase EasingMode="EaseOut"/>
                                                                                        </DoubleAnimation.EasingFunction>
                                                                                    </DoubleAnimation>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </DataTrigger.EnterActions>
                                                                        <DataTrigger.ExitActions>
                                                                            <BeginStoryboard>
                                                                                <Storyboard>
                                                                                    <DoubleAnimation Storyboard.TargetProperty="Height"
                                                                                                     From="35" To="0"
                                                                                                     Duration="0:0:0.2">
                                                                                        <DoubleAnimation.EasingFunction>
                                                                                            <CubicEase EasingMode="EaseIn"/>
                                                                                        </DoubleAnimation.EasingFunction>
                                                                                    </DoubleAnimation>
                                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                     From="1" To="0"
                                                                                                     Duration="0:0:0.15">
                                                                                        <DoubleAnimation.EasingFunction>
                                                                                            <CubicEase EasingMode="EaseIn"/>
                                                                                        </DoubleAnimation.EasingFunction>
                                                                                    </DoubleAnimation>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </DataTrigger.ExitActions>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Content="删除"
                                                                    Command="{Binding DataContext.DeleteTestCardCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding Id}"
                                                                    Padding="2,0"
                                                                    Margin="0"
                                                                    Background="#FFDDDDDD"
                                                                    BorderBrush="#FF999999"
                                                                    BorderThickness="1"
                                                                    FontSize="12"
                                                                    HorizontalAlignment="Left"
                                                                    VerticalAlignment="Center"
                                                                    Height="Auto"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
