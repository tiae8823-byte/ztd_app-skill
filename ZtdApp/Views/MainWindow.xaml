<Window x:Class="ZtdApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZTD - 想法收集"
        Width="500"
        Height="700"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 输入区域 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="想法收集" FontSize="24" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock Text="快速记录你的想法" Opacity="0.7" FontSize="14" Margin="0,0,0,10"/>
            <TextBox x:Name="IdeaInput"
                     Text="{Binding InputContent, UpdateSourceTrigger=PropertyChanged}"
                     KeyDown="OnKeyDown"
                     Padding="10,8"
                     FontSize="14"
                     Margin="0,0,0,10"/>
            <Button Content="添加想法"
                    Command="{Binding AddIdeaCommand}"
                    Height="40"
                    FontSize="14"/>
        </StackPanel>

        <!-- 列表区域 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Ideas}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#F5F5F5"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="12"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                    <TextBlock Text="{Binding Content}"
                                               TextWrapping="Wrap"
                                               FontSize="14"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding CreatedAtDisplay}"
                                               Opacity="0.6"
                                               FontSize="12"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="删除"
                                        Command="{Binding DataContext.DeleteIdeaCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Id}"
                                        Margin="8,0,0,0"
                                        Padding="8,4"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
