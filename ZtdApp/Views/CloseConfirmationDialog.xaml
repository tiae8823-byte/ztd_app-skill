<Window x:Class="ZtdApp.Views.CloseConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="280"
        Height="130"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Background="{StaticResource BrandLight}"
        ShowInTaskbar="False">

    <Border BorderBrush="{StaticResource BrandLightGray}"
            BorderThickness="1"
            ClipToBounds="False">
        <Grid Margin="14,12,14,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题和记住选择 -->
            <StackPanel Grid.Row="0"
                        VerticalAlignment="Center"
                        Margin="0,0,0,8">
                <TextBlock Text="关闭方式"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrandDark}"
                           Margin="0,0,0,6"/>

                <CheckBox x:Name="RememberChoiceCheckBox"
                          Content="记住此选择"
                          Foreground="{StaticResource BrandMidGray}"
                          FontSize="12"
                          VerticalContentAlignment="Center"
                          Margin="0,0,0,0"/>
            </StackPanel>

            <!-- 按钮 -->
            <StackPanel Grid.Row="1"
                       Orientation="Horizontal"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8">
                <Button x:Name="ExitButton"
                        Click="ExitButton_Click"
                        Content="退出"
                        Margin="0,0,6,0"
                        Padding="10,4"
                        FontSize="12"
                        FontWeight="Normal"
                        VerticalContentAlignment="Center"
                        Style="{StaticResource SecondaryButton}"/>

                <Button x:Name="MinimizeToTrayButton"
                        Click="MinimizeToTrayButton_Click"
                        Content="最小化到托盘"
                        Margin="0,0,0,0"
                        Padding="10,4"
                        FontSize="12"
                        FontWeight="Normal"
                        VerticalContentAlignment="Center"
                        Style="{StaticResource PrimaryButton}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
