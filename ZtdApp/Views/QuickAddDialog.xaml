<Window x:Class="ZtdApp.Views.QuickAddDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="快速添加想法"
        Width="480"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style TargetType="Window" x:Key="DialogShadow">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Window">
                        <Border Background="Transparent"
                                Margin="20">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000"
                                                  Opacity="0.2"
                                                  BlurRadius="20"
                                                  ShadowDepth="8"
                                                  Direction="270"/>
                            </Border.Effect>
                            <Border Background="{StaticResource BrandLight}"
                                    CornerRadius="12"
                                    Padding="24">
                                <ContentPresenter/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Style>
        <StaticResource ResourceKey="DialogShadow"/>
    </Window.Style>

    <StackPanel>
        <!-- 标题 -->
        <TextBlock Text="有什么想法？💡"
                   FontSize="{StaticResource FontSizeLarge}"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16"/>

        <!-- 输入框 -->
        <Border Background="{StaticResource BrandLightGray}"
                CornerRadius="8"
                Padding="12">
            <TextBox x:Name="ContentTextBox"
                     Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                     Background="Transparent"
                     BorderThickness="0"
                     FontSize="{StaticResource FontSizeMedium}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MaxHeight="120"
                     VerticalScrollBarVisibility="Auto">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter"
                                 Command="{Binding AddIdeaCommand}"
                                 Modifiers="None"/>
                </TextBox.InputBindings>
            </TextBox>
        </Border>

        <!-- 提示文字 -->
        <TextBlock Text="按 Enter 快速添加，Esc 关闭"
                   FontSize="{StaticResource FontSizeSmall}"
                   Foreground="{StaticResource BrandMidGray}"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,16"/>

        <!-- 按钮区域 -->
        <StackPanel Orientation="Horizontal"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,0">
            <Button Content="清空"
                    Command="{Binding ClearCommand}"
                    Width="80"
                    Height="36"
                    Margin="0,0,12,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Background" Value="{StaticResource BrandLightGray}"/>
                        <Setter Property="Foreground" Value="{StaticResource BrandDark}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#d8d6cc"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="添加"
                    Command="{Binding AddIdeaCommand}"
                    Width="80"
                    Height="36"/>
        </StackPanel>
    </StackPanel>
</Window>
