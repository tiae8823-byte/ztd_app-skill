<Window x:Class="ZtdApp.Views.QuickAddDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="快速添加想法"
        Width="380"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">

    <!-- 窗口阴影容器 -->
    <Border Background="Transparent" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="#000000"
                              Opacity="0.15"
                              BlurRadius="16"
                              ShadowDepth="4"
                              Direction="270"/>
        </Border.Effect>

        <!-- 主内容区 -->
        <Border Background="{StaticResource BrandLight}"
                CornerRadius="10"
                Padding="16">
            <StackPanel>
                <!-- 输入框容器 -->
                <Grid>
                    <!-- Placeholder 提示层 -->
                    <TextBlock x:Name="PlaceholderText"
                               Text="💡 有什么想法？Enter 添加 · Esc 关闭 · Tab 清空"
                               Foreground="{StaticResource BrandMidGray}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               IsHitTestVisible="False"
                               Margin="12,6,0,0"/>

                    <!-- 输入框 -->
                    <TextBox x:Name="ContentTextBox"
                             Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             BorderThickness="0"
                             FontSize="14"
                             AcceptsReturn="False"
                             TextWrapping="Wrap"
                             MaxHeight="120"
                             VerticalScrollBarVisibility="Auto"
                             Padding="8,6"
                             Margin="0,0,0,0"
                             KeyDown="TextBox_KeyDown"
                             TextChanged="ContentTextBox_TextChanged">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="CaretBrush" Value="{StaticResource BrandDark}"/>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Grid>
            </StackPanel>
        </Border>
    </Border>
</Window>
